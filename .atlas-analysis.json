  "keyFeatures": [
    "Real-time parking spot monitoring with <2s latency",
    "ESP32-based IoT sensors with self-healing capabilities",
    "Cloud-native serverless architecture on Google Cloud Platform",
    "Visual zone builder with drag-and-drop parking spot creation",
    "Reservation system with automatic expiration handling",
    "Analytics dashboard with occupancy trends and peak hours",
    "Multi-layer caching with Page Visibility API optimization",
    "Firebase Authentication with custom claims",
    "Firestore real-time database with historical snapshots",
    "LED visual feedback system (RGB indicators)"
  ],
  "publicApiSurface": [
    "POST /ingest-parking-data - Ingest sensor data from ESP32 devices",
    "GET /get-parking-status - Fetch current status of all parking spots",
    "POST /reserve-parking-spot - Reserve a parking spot with duration",
    "POST /release-parking-spot - Release a reserved parking spot",
    "POST /create-parking-spot - Create a new parking spot",
    "DELETE /delete-parking-spot - Delete an existing parking spot",
    "POST /manage-zones - Create, update, or delete parking zones",
    "GET /get-zones - Fetch all parking zones",
    "GET /get-occupancy-history - Retrieve historical occupancy data",
    "POST /save-hourly-snapshot - Trigger hourly snapshot generation"
  ]
